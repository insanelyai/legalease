generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  name          String
  picture       String?
  isGoogle      Boolean         @default(false)
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  conversations Conversations[]
  messages      Messages[]
}

model Conversations {
  id         String     @id @default(uuid())
  userId     String
  legal_area LEGAL_AREA
  title      String?
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   Messages[]
}

model Messages {
  id             String        @id @default(uuid())
  conversationId String
  userId         String
  role           ROLE
  content        String
  created_at     DateTime      @default(now())
  conversation   Conversations @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model legal_chunks {
  id                    String   @id @default(uuid())
  text                  String
  chunk_type            String?
  parent_id             String?
  act_name              String?
  act_year              Int?
  law_type              String?
  chapter_num           String?
  chapter_title         String?
  section_num           String?
  section_title         String?

  has_proviso           Boolean? @default(false)
  has_explanation       Boolean? @default(false)
  is_definition_section Boolean? @default(false)

  cross_refs            String[]
  source_file           String?
  page_range            Int[]

  chunk_index           Int?
  word_count            Int?

  embedding             Unsupported("vector")
  fts                   Unsupported("tsvector")

  ingested_at           DateTime? @default(now()) @db.Timestamptz(6)

  @@index([act_name])
  @@index([chunk_type])
  @@index([law_type])
  @@index([parent_id])
  @@index([section_num])
  @@index([fts], type: Gin)
}

enum LEGAL_AREA {
  CONSUMER
  LABOUR
  FAMILY
}

enum ROLE {
  USER
  ASSISTANT
}
